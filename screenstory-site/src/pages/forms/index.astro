---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Base.astro';

const forms = await getCollection('forms');
---

<Layout title="Forms" description="Business forms and briefs.">
  <h1>Forms</h1>
  <div class="card-grid">
    {forms.map(f => (
      <a href={`/forms/${f.slug}/`} class="card" style="display:block;">
        <h3>{f.data.title}</h3>
        {f.data.description && <p>{f.data.description}</p>}
      </a>
    ))}
  </div>
</Layout>
