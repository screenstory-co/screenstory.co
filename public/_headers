/* Cache static assets aggressively */
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/uploads/*
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable

/*.js
  Cache-Control: public, max-age=31536000, immutable

/* HTML pages — short cache for quick updates */
/*.html
  Cache-Control: public, max-age=0, must-revalidate